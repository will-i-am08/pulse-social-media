# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Site URL (used for auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Buffer (social media scheduling)
BUFFER_API_KEY=1/...

# Replicate (AI image generation & model training)
REPLICATE_API_TOKEN=r8_...

# GitHub (blog sync & CMS integrations)
GITHUB_TOKEN=ghp_...

# Encryption (must be at least 32 characters)
ENCRYPTION_SECRET=your-32-character-secret-key-here!!
